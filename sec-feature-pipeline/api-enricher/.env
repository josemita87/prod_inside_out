
#Kakfa settings
KAFKA_BROKER_ADDRESS=redpanda-0:9092
KAFKA_INPUT_TOPIC=form-4-dictionary-v2
KAFKA_OUTPUT_TOPIC=form-4-enriched-v2
AUTO_OFFSET_RESET=earliest
CONSUMER_GROUP=api-enricher-v3

# Paths for main data files
MCAPS_PATH=/app/src/data/mcaps.parquet
MAPPER_PATH=/app/src/data/mapper.json

# Paths for failed records
FAILED_MCAPS_PATH=/app/src/data/failed/failed_mcaps.parquet
FAILED_DATE_PATH=/app/src/data/failed/failed_date.parquet
FAILED_SIC_PATH=/app/src/data/failed/failed_mapper.parquet
FAILED_EXCHANGE_PATH=/app/src/data/failed/failed_exchange.parquet


# Common settings

POLL_TIMEOUT=5
BUFFER_SIZE=1000

DELAY=0
SLEEP_TIME=0