# Ignore all Python files by default
*.py

# But not these directories where actual code is located
!src/
!app/
!project_name/

# Ignore virtual environment folders
venv/
env/

# Ignore .pyc, .pyo, .pyd files (compiled files)
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Ignore site-packages (dependencies installed by pip, poetry, etc.)
site-packages/

# Ignore all logs, databases, temporary files, etc.
*.log
*.db
*.sqlite3

# Ignore IDE and editor-specific files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Ignore sensitive credentials files
**/.credentials.env

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore dependency management files (if you don't want to track them)
# Pipfile
# Pipfile.lock
# poetry.lock
# pyproject.toml

# Ignore any other unnecessary files (generated files)
*.swp
*.tmp
